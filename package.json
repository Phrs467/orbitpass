{
  "name": "orbitpass-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web -- -p 3005",
    "dev": "npx concurrently \"npm run dev:api\" \"npm run dev:web\""
  }
}
