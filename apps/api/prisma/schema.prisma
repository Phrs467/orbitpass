generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  cpfEncrypted     String   @unique
  role             String   // ADMIN, PRODUCER, CUSTOMER
  isVerified       Boolean  @default(false)
  stripeAccountId  String?
  createdAt        DateTime @default(now())

  events           Event[]
  ownedTickets     Ticket[] @relation("TicketOwner")
  transactionsFrom Transaction[] @relation("TxFrom")
  transactionsTo   Transaction[] @relation("TxTo")
}

model Event {
  id             String   @id @default(uuid())
  producerId     String
  name           String
  description    String?
  location       String
  date           DateTime
  status         String   // DRAFT, PUBLISHED, CANCELLED, FINISHED
  createdAt      DateTime @default(now())

  producer       User     @relation(fields: [producerId], references: [id])
  ticketLots     TicketLot[]
}

model TicketLot {
  id               String   @id @default(uuid())
  eventId          String
  name             String
  price            Decimal
  totalQuantity    Int
  soldQuantity     Int      @default(0)
  platformFeePct   Decimal
  status           String   // ACTIVE, EXHAUSTED, CLOSED
  
  event            Event    @relation(fields: [eventId], references: [id])
  tickets          Ticket[]
}

model Ticket {
  id                 String   @id @default(uuid())
  lotId              String
  currentOwnerId     String
  status             String   // AVAILABLE, RESERVED, SOLD, RESELLING, CHECKED_IN
  dynamicQrSecret    String
  
  lot                TicketLot @relation(fields: [lotId], references: [id])
  currentOwner       User      @relation("TicketOwner", fields: [currentOwnerId], references: [id])
  transactions       Transaction[]
  checkin            Checkin?
}

model Transaction {
  id                 String   @id @default(uuid())
  ticketId           String
  fromUserId         String?
  toUserId           String
  type               String   // PRIMARY_SALE, TRANSFER, RESALE
  amount             Decimal
  platformFee        Decimal
  status             String   // PENDING, COMPLETED, ESCROW, REFUNDED
  stripePaymentId    String?
  escrowReleaseDate  DateTime?
  createdAt          DateTime @default(now())

  ticket             Ticket   @relation(fields: [ticketId], references: [id])
  fromUser           User?    @relation("TxFrom", fields: [fromUserId], references: [id])
  toUser             User     @relation("TxTo", fields: [toUserId], references: [id])
}

model Checkin {
  id             String   @id @default(uuid())
  ticketId       String   @unique
  validatedAt    DateTime @default(now())
  validatorId    String

  ticket         Ticket   @relation(fields: [ticketId], references: [id])
}
